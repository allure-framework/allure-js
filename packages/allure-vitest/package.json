{
  "name": "allure-vitest",
  "version": "3.6.0",
  "description": "Allure Vitest integration",
  "keywords": [
    "allure",
    "html",
    "report",
    "reporter",
    "test",
    "testing",
    "testops",
    "vitest"
  ],
  "homepage": "https://allurereport.org/",
  "license": "Apache-2.0",
  "author": {
    "name": "Qameta Software",
    "email": "allure@qameta.io",
    "url": "https://qameta.io/"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/allure-framework/allure-js.git",
    "directory": "packages/allure-vitest"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    "./reporter": {
      "types": "./dist/reporter.d.ts",
      "import": "./dist/reporter.js",
      "default": "./dist/reporter.js"
    },
    "./setup": {
      "types": "./dist/setup.d.ts",
      "import": "./dist/setup.js",
      "default": "./dist/setup.js"
    },
    "./browser": {
      "types": "./dist/browser/index.d.ts",
      "import": "./dist/browser/index.js",
      "default": "./dist/browser/index.js"
    },
    "./browser/setup": {
      "types": "./dist/browser/setup.d.ts",
      "import": "./dist/browser/setup.js",
      "default": "./dist/browser/setup.js"
    }
  },
  "scripts": {
    "allure-report": "allure serve ./out/allure-results",
    "clean": "rimraf ./dist ./out",
    "compile": "tsc --project ./tsconfig.json",
    "generate-report": "allure generate ./out/allure-results -o ./out/allure-report --clean --single-file",
    "lint": "oxlint --import-plugin src test",
    "lint:fix": "oxlint --import-plugin --fix src test",
    "pretest": "run-p clean compile",
    "test": "vitest run"
  },
  "dependencies": {
    "allure-js-commons": "workspace:*"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.19.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/runner": "^4.0.18",
    "allure-commandline": "^2.29.0",
    "npm-run-all2": "^8.0.0",
    "playwright": "^1.58.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rimraf": "^6.0.0",
    "typescript": "^5.2.2",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "@vitest/runner": ">=1.3.0",
    "vitest": ">=1.3.0"
  }
}
