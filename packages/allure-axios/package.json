{
  "name": "allure-axios",
  "version": "3.10.1",
  "description": "Allure Axios HTTP client integration",
  "keywords": [
    "allure",
    "axios",
    "html",
    "http",
    "report",
    "testing",
    "testops"
  ],
  "homepage": "https://allurereport.org/",
  "license": "Apache-2.0",
  "author": {
    "name": "Qameta Software",
    "email": "allure@qameta.io",
    "url": "https://qameta.io/"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/allure-framework/allure-js.git",
    "directory": "packages/allure-axios"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "scripts": {
    "allure-report": "allure serve ./out/allure-results",
    "clean": "rimraf ./dist ./out",
    "compile": "run-s 'compile:*'",
    "compile:esm": "babel --config-file ./babel.esm.json ./src --out-dir ./dist/esm --extensions '.ts' --source-maps",
    "compile:cjs": "babel --config-file ./babel.cjs.json ./src --out-dir ./dist/cjs --extensions '.ts' --source-maps",
    "compile:types": "tsc",
    "compile:fixup": "node ./scripts/fixup.mjs",
    "generate-report": "allure generate ./out/allure-results -o ./out/allure-report --clean",
    "lint": "yarn run -T oxlint --import-plugin src test",
    "lint:fix": "yarn run -T oxlint --import-plugin --fix src test",
    "test": "run-s test:prepare test:run",
    "test:prepare": "yarn workspace allure-js-commons compile && yarn workspace allure-vitest compile && yarn run compile",
    "test:run": "vitest run"
  },
  "dependencies": {
    "allure-js-commons": "workspace:*"
  },
  "devDependencies": {
    "@babel/cli": "^8.0.1",
    "@babel/core": "^7.28.0",
    "@babel/preset-env": "^7.28.0",
    "@babel/preset-typescript": "^7.27.1",
    "@types/babel__core": "^7.20.5",
    "@types/babel__preset-env": "^7.10.0",
    "@types/node": "^20.19.0",
    "allure-commandline": "^2.29.0",
    "allure-vitest": "workspace:*",
    "axios": "1.16.1",
    "babel-plugin-add-module-exports": "^1.0.4",
    "npm-run-all2": "^9.0.2",
    "rimraf": "^6.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.0"
  },
  "peerDependencies": {
    "axios": ">=1.16.0 <2"
  }
}
