{
  "name": "allure-ava",
  "version": "3.9.0",
  "description": "Allure AVA integration",
  "keywords": [
    "allure",
    "ava",
    "html",
    "report",
    "reporter",
    "test",
    "testing",
    "testops"
  ],
  "homepage": "https://allurereport.org/",
  "license": "Apache-2.0",
  "author": {
    "name": "Qameta Software",
    "email": "allure@qameta.io",
    "url": "https://qameta.io/"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/allure-framework/allure-js.git",
    "directory": "packages/allure-ava"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./setup": {
      "types": "./dist/setup.d.ts",
      "import": "./dist/setup.js",
      "default": "./dist/setup.js"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "import": "./dist/runtime.js",
      "default": "./dist/runtime.js"
    }
  },
  "scripts": {
    "allure-report": "allure serve ./out/allure-results",
    "clean": "rimraf ./dist ./out",
    "compile": "tsc --project ./tsconfig.json",
    "generate-report": "allure generate ./out/allure-results -o ./out/allure-report --clean --single-file",
    "lint": "oxlint --import-plugin src test",
    "lint:fix": "oxlint --import-plugin --fix src test",
    "test": "yarn workspace allure-js-commons compile && run-s clean compile && vitest run"
  },
  "dependencies": {
    "allure-js-commons": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.19.0",
    "allure-commandline": "^2.29.0",
    "allure-vitest": "workspace:*",
    "ava": "^8.0.1",
    "npm-run-all2": "^8.0.0",
    "rimraf": "^6.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.0"
  },
  "peerDependencies": {
    "ava": ">=8.0.0"
  }
}
