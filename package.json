{
  "name": "allure-js",
  "version": "3.5.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "yarn run clean && yarn run compile",
    "clean": "yarn workspaces foreach -Avvt run clean",
    "compile": "yarn workspaces foreach -Avvt run compile",
    "lint": "yarn workspaces foreach -Avvt run lint",
    "lint:fix": "yarn workspaces foreach -Avvt run lint:fix",
    "lint:type": "yarn oxlint --type-aware --import-plugin packages",
    "format": "yarn format:write",
    "format:check": "node ./scripts/run-oxfmt.cjs --check",
    "format:write": "node ./scripts/run-oxfmt.cjs --write",
    "verify": "yarn format:check && yarn lint && yarn lint:type --quiet",
    "prepare": "husky install",
    "test": "yarn workspaces foreach -Avvt run test"
  },
  "devDependencies": {
    "husky": "^9.0.0",
    "lint-staged": "^16.0.0",
    "oxfmt": "0.36.0",
    "oxlint": "1.51.0",
    "oxlint-tsgolint": "0.16.0",
    "rimraf": "^6.0.0",
    "typescript": "^5.2.2"
  },
  "resolutions": {
    "@babel/helpers": "^7.26.10",
    "@babel/runtime": "^7.26.10",
    "ajv@npm:^8.6.3": "8.18.0",
    "assertion-error-formatter@^3/diff": "^4.0.4",
    "axios": "^1.13.5",
    "braces": "^3.0.3",
    "cookie": "^1.0.0",
    "cross-spawn": "^7.0.6",
    "diff@npm:^4.0.1": "4.0.4",
    "jose": "^4.15.5",
    "js-yaml": "^4.1.1",
    "lodash": "^4.17.23",
    "minimatch@npm:2 || 3": "3.1.3",
    "minimatch@npm:3.1.3": "3.1.5",
    "minimatch@npm:9.0.1": "9.0.7",
    "minimatch@npm:^10.0.1": "10.2.3",
    "minimatch@npm:^10.1.1": "10.2.3",
    "minimatch@npm:^3.0.2": "3.1.5",
    "minimatch@npm:^3.0.4": "3.1.5",
    "minimatch@npm:^3.0.5": "3.1.5",
    "minimatch@npm:^3.1.1": "3.1.5",
    "minimatch@npm:^3.1.2": "3.1.5",
    "minimatch@npm:^5.0.1": "5.1.8",
    "minimatch@npm:^5.1.6": "5.1.8",
    "minimatch@npm:^9.0.4": "9.0.7",
    "minimatch@npm:^9.0.5": "9.0.7",
    "mocha@^11/diff": "^5.2.2",
    "multer@npm:^2.0.2": "2.1.0",
    "node-forge@npm:1.3.1": "npm:^1.3.3",
    "qs": "^6.14.2",
    "serialize-javascript": "^7.0.3",
    "tar": "^7.5.7",
    "tmp": "^0.2.5",
    "underscore": "^1.13.8",
    "undici": "^7.18.2"
  },
  "lint-staged": {
    "packages/*/{src,test,features}/**/*.{mjs,cjs,js,ts,tsx}": [
      "oxlint --fix",
      "oxfmt --write"
    ],
    "**/package.json": [
      "oxfmt --write"
    ]
  },
  "packageManager": "yarn@4.12.0"
}
