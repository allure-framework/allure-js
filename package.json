{
  "name": "allure-js",
  "version": "3.10.1",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "audit": "yarn npm audit --all --recursive",
    "build": "yarn run clean && yarn run compile",
    "build:ci": "yarn workspaces foreach -A -p --topological-dev -i -v run compile",
    "clean": "yarn workspaces foreach -Avvt run clean",
    "compile": "yarn workspaces foreach -Avvt run compile",
    "lint": "yarn workspaces foreach -Avvt run lint",
    "lint:fix": "yarn workspaces foreach -Avvt run lint:fix",
    "lint:type": "yarn oxlint --type-aware --import-plugin packages",
    "format": "yarn format:write",
    "format:check": "yarn oxfmt --check",
    "format:write": "yarn oxfmt --write",
    "verify": "yarn format:check && yarn lint && yarn lint:type --quiet",
    "test": "yarn workspaces foreach -Avvt run test"
  },
  "devDependencies": {
    "allure": "^3.10.0",
    "lefthook": "^2.1.4",
    "oxfmt": "0.54.0",
    "oxlint": "1.64.0",
    "oxlint-tsgolint": "0.19.0",
    "rimraf": "^6.0.0",
    "typescript": "^6.0.3"
  },
  "resolutions": {
    "@babel/core": "npm:7.29.7",
    "@babel/plugin-transform-modules-systemjs": "npm:7.29.7",
    "@xmldom/xmldom": "npm:0.9.10",
    "axios@npm:1.13.6": "npm:1.16.0",
    "brace-expansion": "npm:5.0.6",
    "cookie@npm:^0.4.2": "npm:0.7.2",
    "diff@npm:^7.0.0": "npm:8.0.4",
    "dompurify": "npm:3.4.11",
    "fast-uri": "npm:3.1.2",
    "flatted@npm:3.2.6": "npm:3.4.2",
    "form-data": "npm:4.0.6",
    "handlebars@npm:4.7.8": "npm:4.7.9",
    "ip-address": "npm:10.2.0",
    "joi": "npm:18.2.3",
    "jose@npm:4.14.4": "npm:4.15.5",
    "js-yaml": "npm:4.2.0",
    "lodash": "npm:4.18.1",
    "lodash@npm:4.17.21": "npm:4.18.1",
    "markdown-it": "npm:14.2.0",
    "minimatch@npm:9.0.1": "npm:9.0.9",
    "multer": "npm:2.2.0",
    "node-forge@npm:1.3.1": "npm:1.4.0",
    "qs": "npm:6.15.3",
    "qs@npm:6.14.0": "npm:6.15.3",
    "qs@npm:~6.5.3": "npm:6.15.3",
    "serialize-javascript@npm:^6.0.2": "npm:7.0.5",
    "tar": "npm:7.5.17",
    "tar@npm:^6.1.11": "npm:7.5.17",
    "tar@npm:^6.1.2": "npm:7.5.17",
    "tmp": "npm:0.2.7",
    "tmp@npm:0.2.3": "npm:0.2.7",
    "tmp@npm:^0.0.33": "npm:0.2.7",
    "underscore@npm:~1.12.1": "npm:1.13.8",
    "undici": "npm:7.28.0",
    "uuid": "npm:11.1.1",
    "ws@npm:^6.2.3": "npm:6.2.4",
    "ws@npm:^7": "npm:7.5.11",
    "ws@npm:^7.0.0": "npm:7.5.11",
    "ws@npm:^7.2.0": "npm:7.5.11",
    "ws@npm:^7.4.6": "npm:7.5.11",
    "ws@npm:^7.5.10": "npm:7.5.11",
    "ws@npm:^8.18.0": "npm:8.21.0",
    "ws@npm:^8.19.0": "npm:8.21.0"
  },
  "packageManager": "yarn@4.13.0"
}
