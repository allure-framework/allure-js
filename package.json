{
  "name": "allure-js",
  "version": "3.6.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "audit": "yarn npm audit --all --recursive",
    "build": "yarn run clean && yarn run compile",
    "build:ci": "yarn workspaces foreach -A -p --topological-dev -i -v run compile",
    "clean": "yarn workspaces foreach -Avvt run clean",
    "compile": "yarn workspaces foreach -Avvt run compile",
    "lint": "yarn workspaces foreach -Avvt run lint",
    "lint:fix": "yarn workspaces foreach -Avvt run lint:fix",
    "lint:type": "yarn oxlint --type-aware --import-plugin packages",
    "format": "yarn format:write",
    "format:check": "yarn oxfmt --check",
    "format:write": "yarn oxfmt --write",
    "verify": "yarn format:check && yarn lint && yarn lint:type --quiet",
    "test": "yarn workspaces foreach -Avvt run test"
  },
  "devDependencies": {
    "lefthook": "^2.1.4",
    "oxfmt": "0.43.0",
    "oxlint": "1.58.0",
    "oxlint-tsgolint": "0.19.0",
    "rimraf": "^6.0.0",
    "typescript": "^5.2.2"
  },
  "resolutions": {
    "@xmldom/xmldom": "npm:0.9.9",
    "cookie@npm:^0.4.2": "npm:0.7.2",
    "diff@npm:^7.0.0": "npm:8.0.4",
    "flatted@npm:3.2.6": "npm:3.4.2",
    "handlebars@npm:4.7.8": "npm:4.7.9",
    "jose@npm:4.14.4": "npm:4.15.5",
    "lodash@npm:4.17.21": "npm:4.17.23",
    "minimatch@npm:9.0.1": "npm:9.0.9",
    "node-forge@npm:1.3.1": "npm:1.4.0",
    "qs@npm:6.14.0": "npm:6.14.2",
    "qs@npm:~6.5.3": "npm:6.15.0",
    "serialize-javascript@npm:^6.0.2": "npm:7.0.5",
    "tar@npm:^6.1.11": "npm:7.5.13",
    "tar@npm:^6.1.2": "npm:7.5.13",
    "tmp@npm:0.2.3": "npm:0.2.5",
    "tmp@npm:^0.0.33": "npm:0.2.5",
    "underscore@npm:~1.12.1": "npm:1.13.8"
  },
  "packageManager": "yarn@4.13.0"
}
