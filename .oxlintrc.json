{
  "$schema": "https://raw.githubusercontent.com/oxc-project/oxc/refs/heads/main/npm/oxlint/configuration_schema.json",
  "plugins": ["typescript", "import", "jsdoc", "node"],
  "env": {
    "browser": true,
    "node": true
  },
  "ignorePatterns": [
    "**/.yarn/**",
    "**/node_modules/**",
    "**/dist/**",
    "**/out/**",
    "**/.pnp.*",
    "**/allure-report/**",
    "**/test/fixtures/**"
  ]
}
